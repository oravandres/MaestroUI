# Copy to `.env.development` for local development.
# Public values only in Vite variables — every `VITE_*` value is embedded in
# the browser bundle.

# Optional public Maestro HTTP API base URL override (no trailing slash).
# Leave unset to use same-origin `/api/v1/*` requests through the Vite/nginx
# proxy path.
# VITE_MAESTRO_API_BASE_URL=http://localhost:8002
# VITE_MAESTRO_API_BASE_URL=https://maestro.mimi.local

# Server-only local/proxy settings. These are read by Vite's dev server and by
# the production nginx container runtime, not by browser code.
# MAESTRO_API_PROXY_TARGET=http://localhost:8002
# MAESTRO_API_KEY=replace-with-local-api-key
